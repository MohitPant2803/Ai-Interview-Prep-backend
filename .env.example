PORT=5000
# MongoDB Atlas Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/online-interviewer?retryWrites=true&w=majority

# JWT signing secret (change this to any long random string)
JWT_SECRET=supersecretjwtsessiontokenkey123!

# Google Cloud Console OAuth 2.0 Web Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
